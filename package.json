{
  "name": "confluence-obsidian-sync",
  "version": "0.1.5",
  "description": "Confluence 문서를 Obsidian 로컬 Markdown 작업 사본으로 동기화하는 플러그인",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.config.mjs && node scripts/copy-plugin-assets.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "smoke:graphify": "node scripts/smoke-graphify-output.mjs",
    "package:plugin": "pnpm run build && node scripts/package-plugin.mjs",
    "prepare:current-vault": "pnpm run build && node scripts/prepare-current-vault.mjs",
    "prepare:vault": "pnpm run build && node scripts/prepare-vault-template.mjs",
    "verify": "pnpm run lint && pnpm run test && pnpm run build",
    "release:local": "pnpm run verify && pnpm run package:plugin"
  },
  "keywords": [
    "obsidian",
    "confluence",
    "markdown"
  ],
  "author": "Confluence Obsidian Sync",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.8.0",
    "tslib": "^2.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "linkedom": "^0.18.12"
  }
}
